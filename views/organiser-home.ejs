<!DOCTYPE html>
<html>

<head>
    <title>Organiser Home</title>
    <link rel="stylesheet" href="/main.css">
</head>

<body>
    <%- include('add-ons') %>

        <h1>
            <%= site.name %>
        </h1>
        <p>
            <%= site.description %>
        </p>
        <p class="page-description">
            Here you can create new events or manage your draft and published events, view ticket details, and access
            attendee links.
        </p>

        <h2>Draft Events</h2>

        <ul>
            <% drafts.forEach(event=> { %> <!-- Loop through all draft events -->
                <li>
                    <p><strong>Title:</strong>
                        <%= event.title %>
                    </p>
                    <p><strong>Date:</strong>
                        <%= event.event_date %>
                    </p>
                    <p><strong>Venue:</strong>
                        <%= event.venue_name ? `${event.venue_name} (${event.venue_city})` : "Not assigned" %>
                    </p>

                    <!-- Tickets -->
                    <% if (ticketMap[event.event_id]) { %>
                        <ul>
                            <% ticketMap[event.event_id].forEach(ticket=> { %>
                                <li>
                                    <%= ticket.type %>: <%= ticket.price %> SEK — <%= ticket.quantity %> available
                                </li>
                                <% }) %>
                        </ul>
                        <% } else { %>
                            <p><em>No tickets defined yet</em></p>
                            <% } %>

                                <!-- Buttons -->
                                <div style="margin-top: 10px;">
                                    <!-- Edit event-->
                                    <a href="/organiser/edit/<%= event.event_id %>" class="btn">Edit</a>

                                    <!-- Publish event-->
                                    <form action="/organiser/publish/<%= event.event_id %>" method="post"
                                        style="display:inline;">
                                        <button type="submit" class="btn">Publish</button>
                                    </form>

                                    <!-- Attendee view -->
                                    <a href="/attendee/event/<%= event.event_id %>" class="btn" target="_blank">Attendee
                                        Link</a>

                                    <!-- Delete event-->
                                    <form action="/organiser/delete/<%= event.event_id %>" method="post"
                                        style="display:inline;">
                                        <button type="submit" class="btn"
                                            onclick="return confirm('Are you sure you want to delete this event?');">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                </li>
                <% }) %>
        </ul>

        <h2>Published Events</h2>

        <ul>
            <% published.forEach(event=> { %>
                <li>
                    <p><strong>Title:</strong>
                        <%= event.title %>
                    </p>
                    <p><strong>Date:</strong>
                        <%= event.event_date %>
                    </p>
                    <p><strong>Venue:</strong>
                        <%= event.venue_name ? `${event.venue_name} (${event.venue_city})` : "Not assigned" %>
                    </p>

                    <!-- Ticket info -->
                    <% if (ticketMap[event.event_id]) { %>
                        <ul>
                            <% ticketMap[event.event_id].forEach(ticket=> { %>
                                <li>
                                    <%= ticket.type %>: <%= ticket.price %> SEK — <%= ticket.quantity %> available
                                </li>
                                <% }) %>
                        </ul>
                        <% } else { %>
                            <p><em>No tickets defined yet</em></p>
                            <% } %>

                                <!-- Buttons -->
                                <div style="margin-top: 10px;">
                                    <a href="/organiser/edit/<%= event.event_id %>" class="btn">Edit</a>

                                    <!-- Attendee view -->
                                    <a href="/attendee/event/<%= event.event_id %>" class="btn" target="_blank">Attendee
                                        Link</a>

                                    <!-- Submit event-->
                                    <form action="/organiser/delete/<%= event.event_id %>" method="post"
                                        style="display:inline;">
                                        <button type="submit"
                                            onclick="return confirm('Are you sure you want to delete this event?');"
                                            class="btn">Delete</button>
                                    </form>
                                </div>
                </li>
                <% }) %>
        </ul>

        <!-- Form to add new event -->
        <h2>Create New Event</h2>

        <form class="block-form" action="/organiser/create" method="post">
            <button type="submit" class="btn">Create New Event</button>
        </form>

        <a href="/" class="footer-link">
            << Back to Home</a>
</body>

</html>